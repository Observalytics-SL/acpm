{
  "@context": {
    "@version": 1.1,
    "sc": "https://github.com/Observalytics-SL/acpm/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "acpm": "https://github.com/Observalytics-SL/acpm/vocab#",

    "sc_standard":   { "@id": "sc:standard", "@type": "xsd:string" },
    "sc_version":    { "@id": "sc:version",  "@type": "xsd:string" },
    "profile_id":    { "@id": "sc:profileId", "@type": "@id" },

    "subject":        { "@id": "acpm:Subject" },
    "subject_type":   { "@id": "acpm:subjectType" },
    "name":           { "@id": "schema:name" },
    "vendor":         { "@id": "schema:provider" },
    "version":        { "@id": "schema:version" },
    "homepage":       { "@id": "schema:url", "@type": "@id" },
    "sc_refs":        { "@id": "dcterms:relation", "@container": "@list" },
    "standard":       { "@id": "acpm:scRefStandard" },
    "id":             { "@id": "acpm:scRefId" },

    "capabilities":      { "@id": "acpm:capabilities", "@container": "@list" },
    "support":           { "@id": "acpm:support" },
    "version_constraint":{ "@id": "acpm:versionConstraint" },
    "notes":             { "@id": "schema:description" },

    "tools":               { "@id": "acpm:tools", "@container": "@list" },
    "protocol":            { "@id": "acpm:toolProtocol" },
    "max_concurrent_calls":{ "@id": "acpm:maxConcurrentCalls", "@type": "xsd:integer" },
    "auth_methods":        { "@id": "acpm:authMethods", "@container": "@list" },

    "models":            { "@id": "acpm:models", "@container": "@list" },
    "provider":          { "@id": "acpm:provider" },
    "model_id":          { "@id": "acpm:modelId" },
    "context_window":    { "@id": "acpm:contextWindow", "@type": "xsd:integer" },
    "max_output_tokens": { "@id": "acpm:maxOutputTokens", "@type": "xsd:integer" },
    "modalities":        { "@id": "acpm:modalities", "@container": "@list" },

    "memory":  { "@id": "acpm:memory", "@container": "@list" },
    "backend": { "@id": "acpm:memoryBackend" },
    "scopes":  { "@id": "acpm:memoryScopes", "@container": "@list" },

    "trust":          { "@id": "acpm:trust" },
    "level":          { "@id": "acpm:trustLevel" },
    "attestation":    { "@id": "acpm:attestation" },
    "issuer":         { "@id": "acpm:attestationIssuer" },
    "method":         { "@id": "acpm:attestationMethod" },
    "evidence_url":   { "@id": "acpm:evidenceUrl", "@type": "@id" },
    "issued_at":      { "@id": "acpm:issuedAt", "@type": "xsd:dateTime" },
    "expires_at":     { "@id": "acpm:expiresAt", "@type": "xsd:dateTime" },
    "sandbox":        { "@id": "acpm:sandbox" },
    "isolation":      { "@id": "acpm:isolation" },
    "network_egress": { "@id": "acpm:networkEgress" },

    "cost_profile":  { "@id": "acpm:costProfile" },
    "pricing_model": { "@id": "acpm:pricingModel" },
    "currency":      { "@id": "acpm:currency" },
    "unit_cost":     { "@id": "acpm:unitCost" },
    "per":           { "@id": "acpm:unitCostPer" },
    "amount":        { "@id": "acpm:unitCostAmount", "@type": "xsd:decimal" },
    "free_tier":     { "@id": "acpm:freeTier" },
    "included_units":{ "@id": "acpm:includedUnits", "@type": "xsd:decimal" },
    "period":        { "@id": "acpm:freeTierPeriod" },

    "sla":                { "@id": "acpm:sla" },
    "uptime_pct":         { "@id": "acpm:uptimePct", "@type": "xsd:decimal" },
    "p50_latency_ms":     { "@id": "acpm:p50LatencyMs", "@type": "xsd:decimal" },
    "p99_latency_ms":     { "@id": "acpm:p99LatencyMs", "@type": "xsd:decimal" },
    "support_tier":       { "@id": "acpm:supportTier" },
    "incident_response":  { "@id": "acpm:incidentResponse" },
    "severity1_minutes":  { "@id": "acpm:severity1Minutes", "@type": "xsd:integer" },

    "delegation_rules": { "@id": "acpm:delegationRules", "@container": "@list" },
    "direction":        { "@id": "acpm:delegationDirection" },
    "target":           { "@id": "acpm:delegationTarget" },
    "profile_id_ref":   { "@id": "acpm:targetProfileId", "@type": "@id" },
    "capability_id":    { "@id": "acpm:targetCapabilityId" },
    "trust_level_min":  { "@id": "acpm:trustLevelMin" },
    "condition":        { "@id": "acpm:condition" },
    "lang":             { "@id": "acpm:conditionLang" },
    "expr":             { "@id": "acpm:conditionExpr" },
    "nl":                { "@id": "acpm:conditionNl" },
    "action":           { "@id": "acpm:delegationAction" },

    "compliance":      { "@id": "acpm:compliance" },
    "data_residency":  { "@id": "acpm:dataResidency", "@container": "@list" },
    "certifications":  { "@id": "acpm:certifications", "@container": "@list" },
    "pii_handling":    { "@id": "acpm:piiHandling" },

    "provenance":  { "@id": "acpm:Provenance" },
    "authored_by": { "@id": "dcterms:creator" },
    "created_at":  { "@id": "dcterms:created", "@type": "xsd:dateTime" },
    "updated_at":  { "@id": "dcterms:modified", "@type": "xsd:dateTime" },
    "license":     { "@id": "dcterms:license", "@type": "@id" },
    "signature":   { "@id": "acpm:signature" }
  }
}
